generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  PARENT
  STAFF
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String?           @unique
  image           String?
  role            Role?
  schoolName      String?
  classSection    String?
  studentId       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  attendance      AttendanceEvent[]
  progressRecords ProgressRecord[]
  roomLogs        RoomLog[]
  locations       LocationPing[]
  alerts          SecurityAlert[]
  accounts        Account[]
  sessions        Session[]
}

model AttendanceEvent {
  id         String   @id @default(cuid())
  userId     String
  stationId  String
  status     String
  scannedAt  DateTime
  classLabel String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgressRecord {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  score     Int
  examDate  DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RoomLog {
  id        String   @id @default(cuid())
  userId    String
  room      String
  timeIn    DateTime
  timeOut   DateTime?
  stationId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LocationPing {
  id         String   @id @default(cuid())
  userId     String
  latitude   Float
  longitude  Float
  timestamp  DateTime
  source     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SecurityAlert {
  id         String   @id @default(cuid())
  userId     String?
  stationId  String
  alertType  String
  severity   String
  message    String
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model DeviceStation {
  id          String   @id @default(cuid())
  stationCode String   @unique
  location    String
  status      String
  createdAt   DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
